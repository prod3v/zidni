---
import Base from "@/layouts/Base.astro";
import ServicePage from "@/layouts/ServicePage.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { render } from "astro:content";

export async function getStaticPaths() {
  const pages = await getSinglePage("pages");

  const paths = pages.map((page) => ({
    params: {
      regular: page.id,
    },
    props: { page },
  }));
  return paths;
}

const { page } = Astro.props;
const { title, meta_title, description, image, illustration } = page.data as any;
const isServicePage = !!illustration;

// Only render markdown for non-service pages
let Content: any = null;
if (!isServicePage) {
  const rendered = await render(page);
  Content = rendered.Content;
}
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  {isServicePage ? (
    <ServicePage
      title={title}
      description={description}
      illustration={illustration}
      whatsapp_text={(page.data as any).whatsapp_text}
      feature_heading={(page.data as any).feature_heading}
      feature_text={(page.data as any).feature_text}
      process_steps={(page.data as any).process_steps}
      advantages={(page.data as any).advantages}
      faq={(page.data as any).faq}
    />
  ) : (
    <section class="section">
      <div class="container">
        <h1 set:html={markdownify(title)} class="h2 page-heading" />
        <div class="content">
          {Content && <Content />}
        </div>
      </div>
    </section>
  )}
</Base>
