---
interface Props {
  title?: string;
}

const { title = "ملخص سريع" } = Astro.props;
---

<div class="bg-light border border-border rounded-2xl p-6 my-8">
  <h3 class="text-lg font-bold mb-4 flex items-center gap-2 text-dark">
    <span>📋</span>
    {title}
  </h3>
  <div class="summary-body leading-8 text-text">
    <slot />
  </div>
</div>

<style>
  .summary-body :global(ul),
  .summary-body :global(ol) {
    padding-inline-start: 1.25rem;
    margin: 0;
  }

  .summary-body :global(ul) {
    list-style-type: disc;
  }

  .summary-body :global(ol) {
    list-style-type: decimal;
  }

  .summary-body :global(li) {
    margin: 0.4rem 0;
  }

  .summary-body :global(li)::marker {
    color: var(--color-primary, #01ad9f);
  }

  .summary-body :global(strong) {
    color: var(--color-dark, #152035);
  }

  .summary-body :global(a) {
    color: var(--color-primary, #01ad9f);
  }
</style>
