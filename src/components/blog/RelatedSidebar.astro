---
import dateFormat from "@/lib/utils/dateFormat";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

type Props = {
  posts: CollectionEntry<"posts">[];
};

const { posts } = Astro.props;
---

{
  posts.length > 0 && (
    <aside class="sticky top-24">
      <h3 class="font-bold text-dark mb-5 flex items-center gap-2">
        <span class="w-1 h-5 bg-primary rounded-full inline-block" />
        مقالات ذات صلة
      </h3>
      <div class="space-y-4">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="flex gap-3 group rounded-xl p-2 -m-2 transition duration-200 hover:bg-light"
          >
            {post.data.image && (
              <div class="w-20 h-16 rounded-lg overflow-hidden shrink-0">
                <Image
                  src={post.data.image}
                  alt={post.data.title}
                  width={160}
                  height={128}
                  class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
                />
              </div>
            )}
            <div class="flex-1 min-w-0">
              <h4 class="text-sm font-semibold text-dark leading-snug line-clamp-2 group-hover:text-primary transition duration-200">
                {post.data.title}
              </h4>
              <time class="text-xs text-text/60 mt-1.5 block">
                {dateFormat(post.data.date!)}
              </time>
            </div>
          </a>
        ))}
      </div>

      <!-- Sticky CTA -->
      <div class="mt-8 relative overflow-hidden bg-gradient-to-l from-primary/10 to-primary/5 border border-primary/20 rounded-2xl p-6 text-center">
        <div class="absolute top-0 start-0 w-20 h-20 bg-primary/5 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
        <div class="absolute bottom-0 end-0 w-24 h-24 bg-primary/5 rounded-full translate-x-1/3 translate-y-1/3"></div>
        <div class="relative">
          <h4 class="text-lg font-bold text-dark mb-2">تحتاج مساعدة أكاديمية؟</h4>
          <p class="text-sm text-text mb-4 leading-relaxed">مشاريع تخرج، واجبات، أو ترجمة أكاديمية — فريقنا جاهز يساعدك</p>
          <a
            href="https://wa.me/201557703662"
            class="inline-flex items-center justify-center gap-2 w-full bg-primary text-white px-6 py-3 rounded-xl font-semibold hover:bg-primary/90 transition-colors shadow-sm hover:shadow-md"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            اطلب المساعدة الآن
          </a>
        </div>
      </div>
    </aside>
  )
}
