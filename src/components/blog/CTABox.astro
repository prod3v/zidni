---
interface Props {
  title: string;
  description: string;
  buttonText?: string;
  buttonUrl?: string;
}

const {
  title,
  description,
  buttonText = "تواصل معنا الآن",
  buttonUrl = "https://wa.me/201557703662",
} = Astro.props;
---

<div class="relative overflow-hidden bg-gradient-to-l from-primary/10 to-primary/5 border border-primary/20 rounded-2xl p-8 my-10 text-center">
  <div class="absolute top-0 start-0 w-24 h-24 bg-primary/5 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 end-0 w-32 h-32 bg-primary/5 rounded-full translate-x-1/3 translate-y-1/3"></div>
  <div class="relative">
    <h3 class="text-xl font-bold text-dark mb-3">{title}</h3>
    <p class="text-text mb-5 leading-relaxed max-w-lg mx-auto">{description}</p>
    <a
      href={buttonUrl}
      class="inline-block bg-primary text-white px-8 py-3 rounded-xl font-semibold hover:bg-primary/90 transition-colors shadow-sm hover:shadow-md"
    >
      {buttonText}
    </a>
  </div>
</div>
