---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="my-10">
  {title && <h3 class="text-lg font-bold mb-5 text-dark">{title}</h3>}
  <div class="step-list">
    <slot />
  </div>
</div>

<style>
  .step-list :global(div) {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .step-list :global(div > span) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    min-width: 2.25rem;
    border-radius: 9999px;
    background: var(--color-primary, #01ad9f);
    color: white;
    font-weight: 700;
    font-size: 0.875rem;
  }

  .step-list :global(div > div) {
    padding-top: 0.35rem;
    line-height: 1.8;
  }

  .step-list :global(div > div p) {
    margin: 0.25rem 0;
  }
</style>
