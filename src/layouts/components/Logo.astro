---
import config from "@/config/config.json";
const { src } = Astro.props;
const {
  logo,
  logo_text,
  title,
}: {
  logo: string;
  logo_text: string;
  title: string;
} = config.site;
---

<a href="/" class="navbar-brand flex items-center gap-2">
  {(src || logo) && (
    <img
      src={src ? src : logo}
      alt={title}
      class="h-9 w-9 object-contain"
    />
  )}
  <span class="text-xl font-bold text-primary leading-none">
    {logo_text || title}
  </span>
</a>
