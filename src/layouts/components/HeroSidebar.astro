---
import { humanize } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";

type Props = {
  featuredPost: CollectionEntry<"posts">;
  posts: CollectionEntry<"posts">[];
};

const { featuredPost, posts } = Astro.props;
---

<aside class="flex flex-col h-full">
  {/* Featured sidebar card with image */}
  <a
    href={`/blog/${featuredPost.id}`}
    class="block rounded-xl overflow-hidden group"
  >
    {featuredPost.data.image && (
      <div class="bg-light p-3 rounded-xl overflow-hidden">
        <img
          src={featuredPost.data.image}
          alt={featuredPost.data.title}
          class="w-full aspect-[16/10] object-contain group-hover:scale-[1.03] transition duration-500"
          loading="lazy"
        />
      </div>
    )}
  </a>

  {/* Article list — category label + title, fills remaining space */}
  <div class="flex flex-col flex-1 justify-evenly mt-2">
    {posts.map((post) => (
      <a
        href={`/blog/${post.id}`}
        class="block group py-3 border-t border-[#eee] first:border-t-0"
      >
        {post.data.categories?.[0] && (
          <span class="text-primary text-xs font-bold uppercase tracking-wider">
            {humanize(post.data.categories[0])}
          </span>
        )}
        <h3 class="text-dark font-bold text-sm leading-snug mt-1 group-hover:text-primary transition duration-300 line-clamp-2">
          {post.data.title}
        </h3>
      </a>
    ))}
  </div>
</aside>
