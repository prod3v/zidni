---
import { humanize } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";

type Props = {
  featuredPost: CollectionEntry<"posts">;
  posts: CollectionEntry<"posts">[];
};

const { featuredPost, posts } = Astro.props;
---

<aside class="flex flex-col gap-4">
  {/* Featured sidebar card with image */}
  <a
    href={`/blog/${featuredPost.id}`}
    class="block rounded-xl overflow-hidden group"
  >
    {featuredPost.data.image && (
      <div class="bg-light p-3 rounded-xl">
        <img
          src={featuredPost.data.image}
          alt={featuredPost.data.title}
          class="w-full aspect-[16/10] object-contain group-hover:scale-[1.03] transition duration-500"
          loading="lazy"
        />
      </div>
    )}
    <div class="mt-3">
      {featuredPost.data.categories?.[0] && (
        <span class="text-primary text-xs font-bold uppercase tracking-wider">
          {humanize(featuredPost.data.categories[0])}
        </span>
      )}
      <h3 class="text-dark font-bold text-sm leading-snug mt-1 group-hover:text-primary transition duration-300">
        {featuredPost.data.title}
      </h3>
    </div>
  </a>

  {/* Article list — category label + title */}
  {posts.map((post) => (
    <a
      href={`/blog/${post.id}`}
      class="block group border-t border-[#eee] pt-3"
    >
      {post.data.categories?.[0] && (
        <span class="text-primary text-xs font-bold uppercase tracking-wider">
          {humanize(post.data.categories[0])}
        </span>
      )}
      <h3 class="text-dark font-bold text-sm leading-snug mt-1 group-hover:text-primary transition duration-300">
        {post.data.title}
      </h3>
    </a>
  ))}
</aside>
