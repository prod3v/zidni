---
type Props = {
  heading: string;
  text: string;
  illustration?: string;
};

const { heading, text, illustration } = Astro.props;
---

<section class="bg-[#f8f9fa] py-16 md:py-20">
  <div class="container px-4">
    <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
      {illustration && (
        <div class="flex-1 flex justify-center">
          <img
            src={illustration}
            alt={heading}
            class="w-full max-w-[380px] object-contain rounded-2xl"
          />
        </div>
      )}
      <div class="flex-1">
        <h2 class="text-2xl md:text-3xl font-bold text-dark leading-tight mb-6">
          {heading}
        </h2>
        <p class="text-text text-base md:text-lg leading-relaxed whitespace-pre-line">
          {text}
        </p>
      </div>
    </div>
  </div>
</section>
