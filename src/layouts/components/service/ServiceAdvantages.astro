---
type Props = {
  advantages: { title: string; description: string }[];
  illustration?: string;
};

const { advantages, illustration } = Astro.props;
---

<section class="bg-[#f8f9fa] py-16 md:py-20">
  <div class="container px-4">
    <div class="flex flex-col md:flex-row items-start gap-10 md:gap-16">
      {illustration && (
        <div class="flex-1 flex justify-center md:sticky md:top-24">
          <img
            src={illustration}
            alt="مميزات الخدمة"
            class="w-full max-w-[380px] object-contain rounded-2xl"
          />
        </div>
      )}
      <div class="flex-1">
        <h2 class="text-2xl md:text-3xl font-bold text-dark mb-8">ليش تختارنا</h2>
        <div class="space-y-6">
          {advantages.map((item) => (
            <div class="border-r-4 border-primary pr-4">
              <h3 class="text-lg font-bold text-dark mb-1">{item.title}</h3>
              <p class="text-text text-sm leading-relaxed">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
