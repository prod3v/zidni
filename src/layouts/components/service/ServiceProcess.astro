---
type Props = {
  steps: { title: string; description: string }[];
};

const { steps } = Astro.props;
---

<section class="py-16 md:py-20">
  <div class="container px-4">
    <h2 class="text-2xl md:text-3xl font-bold text-dark text-center mb-12">
      كيف نشتغل
    </h2>
    <div class={`grid grid-cols-1 sm:grid-cols-2 ${steps.length >= 4 ? 'lg:grid-cols-4' : 'lg:grid-cols-3'} gap-8`}>
      {steps.map((step, i) => (
        <div class="text-center">
          <div class="w-14 h-14 bg-primary text-white rounded-full flex items-center justify-center text-xl font-bold mx-auto mb-4">
            {i + 1}
          </div>
          <h3 class="text-lg font-bold text-dark mb-2">{step.title}</h3>
          <p class="text-text text-sm leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
