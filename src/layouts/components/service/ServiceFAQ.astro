---
type Props = {
  items: { question: string; answer: string }[];
};

const { items } = Astro.props;
---

<section class="py-16 md:py-20">
  <div class="container px-4 max-w-3xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-bold text-dark text-center mb-12">
      أسئلة شائعة
    </h2>
    <div class="space-y-0">
      {items.map((item, i) => (
        <details class="group border-b border-[#e5e5e5]" open={i === 0}>
          <summary class="flex items-center justify-between cursor-pointer py-5 text-dark font-bold text-base hover:text-primary transition duration-200 list-none">
            <span>{item.question}</span>
            <svg
              class="w-5 h-5 text-text/50 group-open:rotate-45 transition-transform duration-200 flex-shrink-0 ms-4"
              fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <div class="pb-5 text-text text-sm leading-relaxed">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
