---
import Share from "@/components/Share.astro";
import SimilarPosts from "@/components/SimilarPosts.astro";
import ReadingProgress from "@/components/blog/ReadingProgress.astro";
import RelatedSidebar from "@/components/blog/RelatedSidebar.astro";
import Callout from "@/components/blog/Callout.astro";
import CTABox from "@/components/blog/CTABox.astro";
import StepList from "@/components/blog/StepList.astro";
import QuickSummary from "@/components/blog/QuickSummary.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import readingTime from "@/lib/utils/readingTime";
import similerItems from "@/lib/utils/similarItems";
import { humanize, markdownify, slugify } from "@/lib/utils/textConverter";
import config from "@/config/config.json";
import { Image } from "astro:assets";
import { render } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt, BiTime } from "react-icons/bi";

const allAuthors = await getSinglePage("authors");
const posts = await getSinglePage("posts");
const { post } = Astro.props;
const similarPosts = similerItems(post, posts, post.id);
const { Content } = await render(post);
const { title, description, authors, categories, image, date, updated, tags, faq } =
  post.data;
const readTime = readingTime(post.body ?? "");

const baseUrl = config.site.base_url;
const postUrl = `${baseUrl}/blog/${post.id}`;
const postAuthors = allAuthors.filter((author) =>
  authors.map((a: string) => slugify(a)).includes(slugify(author.data.title)),
);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description: description,
  image: image ? `${baseUrl}${image}` : undefined,
  datePublished: date ? new Date(date).toISOString() : undefined,
  author: postAuthors.map((a) => ({
    "@type": "Person",
    name: a.data.title,
    url: `${baseUrl}/authors/${slugify(a.id)}`,
  })),
  dateModified: updated ? new Date(updated).toISOString() : (date ? new Date(date).toISOString() : undefined),
  publisher: {
    "@type": "Organization",
    name: "زدني",
    url: baseUrl,
    logo: {
      "@type": "ImageObject",
      url: `${baseUrl}${config.site.logo}`,
    },
  },
  mainEntityOfPage: postUrl,
  keywords: tags.join(", "),
  inLanguage: "ar",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "الرئيسية",
      item: baseUrl,
    },
    ...(categories.length > 0
      ? [
          {
            "@type": "ListItem",
            position: 2,
            name: humanize(categories[0]),
            item: `${baseUrl}/categories/${slugify(categories[0])}`,
          },
        ]
      : []),
    {
      "@type": "ListItem",
      position: categories.length > 0 ? 3 : 2,
      name: title,
      item: postUrl,
    },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
{faq && faq.length > 0 && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faq.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  })} />
)}

<ReadingProgress />

<!-- Hero Section (dark background, ArabLMS style) -->
<section class="bg-dark py-12 md:py-16">
  <div class="container">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm" aria-label="مسار التنقل">
      <ol class="hidden md:flex items-center gap-2 text-white/45 font-bold text-xs sm:text-sm uppercase tracking-wide flex-wrap">
        <li class="shrink-0"><a href="/" class="underline underline-offset-2 hover:text-white/70 transition">الرئيسية</a></li>
        <li class="select-none shrink-0">/</li>
        {
          categories.length > 0 && (
            <>
              <li class="shrink-0">
                <a
                  href={`/categories/${slugify(categories[0])}`}
                  class="underline underline-offset-2 hover:text-white/70 transition"
                >
                  {humanize(categories[0])}
                </a>
              </li>
              <li class="select-none shrink-0">/</li>
            </>
          )
        }
        <li class="text-white/60">{title}</li>
      </ol>
    </nav>

    <!-- Hero: Text + Image side by side -->
    <div class="flex flex-col-reverse md:flex-row md:items-center gap-8 md:gap-16">
      <!-- Text Column -->
      <div class="flex-1 min-w-0">
        <!-- Category badges -->
        <div class="flex flex-wrap gap-2 mb-4">
          {
            categories.map((category: string) => (
              <a
                href={`/categories/${slugify(category)}`}
                class="inline-block bg-white/10 text-white text-xs font-semibold px-3 py-1 rounded-full hover:bg-primary transition duration-300"
              >
                {humanize(category)}
              </a>
            ))
          }
        </div>

        <!-- Title -->
        <h1 set:html={markdownify(title)} class="text-2xl sm:text-3xl md:text-4xl font-black text-white leading-relaxed mb-5" />

        <!-- Meta -->
        <div class="flex flex-col gap-1 text-white/50 text-sm mb-4">
          {
            allAuthors
              .filter((author) =>
                authors
                  .map((author: string) => slugify(author))
                  .includes(slugify(author.data.title)),
              )
              .map((author) => (
                <a
                  href={`/authors/${slugify(author.id)}`}
                  class="flex items-center hover:text-white/80 transition"
                >
                  {author.data.image && (
                    <Image
                      src={author.data.image}
                      alt={author.data.title}
                      height={50}
                      width={50}
                      class="me-2 h-7 w-7 rounded-full ring-2 ring-white/20"
                    />
                  )}
                  <span class="font-semibold underline underline-offset-2">{author.data.title}</span>
                </a>
              ))
          }
          <span class="flex items-center gap-1.5">
            <BiCalendarEdit className="h-4 w-4" />
            {dateFormat(date)}
          </span>
        </div>

        <!-- Read time badge -->
        <span class="inline-block bg-white/10 text-white/70 text-xs font-medium px-3 py-1 rounded-full">
          <BiTime className="inline h-3.5 w-3.5 me-1" />
          {readTime}
        </span>
      </div>

      <!-- Image Column -->
      {
        image && (
          <div class="w-full md:w-[340px] lg:w-[420px] shrink-0">
            <div class="relative aspect-[4/3] rounded-xl overflow-hidden bg-white/5">
              <img
                src={image}
                alt={title}
                class="w-full h-full object-contain p-4"
                loading="eager"
              />
            </div>
          </div>
        )
      }
    </div>
  </div>
</section>

<!-- Article Content -->
<section class="section pb-8">
  <div class="container">
    <article>
      <!-- Two-column layout: Content + Sidebar -->
      <div class="row gx-5">
        <!-- Main content -->
        <div class="md:col-8">
          <div class="content mb-12 text-start">
            <Content components={{ Callout, CTABox, StepList, QuickSummary }} />
          </div>

          <!-- FAQ Section -->
          {faq && faq.length > 0 && (
            <div class="mb-12">
              <h2 class="h3 mb-6">أسئلة شائعة</h2>
              <div class="divide-y divide-border">
                {faq.map((item) => (
                  <details class="group py-4">
                    <summary class="flex cursor-pointer items-center justify-between gap-4 font-semibold text-dark list-none">
                      <span>{item.question}</span>
                      <span class="shrink-0 text-primary transition-transform group-open:rotate-45">+</span>
                    </summary>
                    <p class="mt-3 text-text leading-8">{item.answer}</p>
                  </details>
                ))}
              </div>
            </div>
          )}

          <!-- Tags & Share -->
          <div class="border-t border-border pt-8">
            {
              tags.length > 0 && (
                <div class="mb-6">
                  <ul class="flex flex-wrap gap-2">
                    {tags.map((tag: string) => (
                      <li>
                        <a
                          href={`/tags/${slugify(tag)}`}
                          class="inline-block rounded-full border border-border px-4 py-1.5 text-sm font-medium text-dark hover:border-primary hover:bg-primary/5 hover:text-primary transition duration-300"
                        >
                          {humanize(tag)}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )
            }

            <div class="flex items-center justify-between gap-1 sm:gap-2 pt-2">
              <span class="text-sm font-semibold text-dark">شارك المقال</span>
              <Share
                className="social-share"
                title={title}
                description={description}
                slug={post.id}
              />
            </div>
          </div>
        </div>

        <!-- Sidebar (desktop only) -->
        <div class="hidden md:block md:col-4">
          <RelatedSidebar posts={similarPosts.slice(0, 5)} />
        </div>
      </div>
    </article>
  </div>
</section>

<!-- Similar Posts (mobile only) -->
{
  similarPosts.length > 0 && (
    <section class="section pt-0 md:hidden">
      <div class="container">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="h3 whitespace-nowrap">مقالات مشابهة</h2>
          <div class="h-px bg-border flex-1" />
        </div>
        <SimilarPosts posts={similarPosts.slice(0, 3)} />
      </div>
    </section>
  )
}
